# Server
SERVER_PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=dops
DB_SCHEMA=orders

# Redis
REDIS_ADDR=localhost:6379

# NATS
NATS_URL=nats://localhost:4222

# JWT
JWT_ISSUER=your_issuer
JWT_AUDIENCE=your_audience
JWT_SECRET=your_secret_here

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SEC=60

# mTLS (required for production, optional for dev)
MTLS_CERT=../certs/client.crt
MTLS_KEY=../certs/client.key
MTLS_CA_CERT=../certs/ca.crt

# Payment Service
PAYMENT_SERVICE_URL=https://localhost:8081
